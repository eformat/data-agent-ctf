# Hermes Agent — OpenShell sandbox image for retail demo
# Based on official nousresearch/hermes-agent (dashboard + TUI pre-built)
# Build from repo root: podman build -t quay.io/eformat/hermes-openshell:latest -f scripts/Containerfile.hermes-sandbox .

FROM docker.io/nousresearch/hermes-agent:v2026.6.19

USER root

RUN apt-get update -qq && apt-get install -y -qq tar iproute2 socat 2>/dev/null || true

RUN groupadd -g 1001 sandbox 2>/dev/null || true && \
    useradd -m -u 1001 -g sandbox -s /bin/bash -d /sandbox sandbox 2>/dev/null || true

RUN install -d -o sandbox -g sandbox /workspace /sandbox /sandbox/.hermes

RUN chmod -R a+rX /opt/hermes && \
    ln -sf /opt/hermes/.venv/bin/hermes /usr/local/bin/hermes

# Build nodumpable.so — LD_PRELOAD library that calls prctl(PR_SET_DUMPABLE,0)
# before main(). Blocks /proc/PID/environ reads from sibling processes.
COPY scripts/nodumpable.c /tmp/nodumpable.c
RUN gcc -shared -fPIC -o /opt/hermes/nodumpable.so /tmp/nodumpable.c -nostartfiles && \
    rm -f /tmp/nodumpable.c

# Patch: normalize 0.0.0.0/:: to 127.0.0.1 in TUI WebSocket URLs.
COPY scripts/fix-tui-wildcard-bind.py /tmp/fix-tui-wildcard-bind.py
RUN python3 /tmp/fix-tui-wildcard-bind.py \
      /opt/hermes/hermes_cli/web_server.py 2>/dev/null || true && \
    rm -f /tmp/fix-tui-wildcard-bind.py

# Bake non-secret config
COPY scripts/hermes-config/config.yaml /sandbox/.hermes/config.yaml
COPY scripts/hermes-config/active_profile /sandbox/.hermes/active_profile
COPY scripts/hermes-config/profiles/ /sandbox/.hermes/profiles/

# Dashboard theme
COPY scripts/dashboard-themes/redhat.yaml /sandbox/.hermes/dashboard-themes/redhat.yaml
RUN for p in /sandbox/.hermes/profiles/retail-*/; do \
      mkdir -p "${p}dashboard-themes" && \
      cp /sandbox/.hermes/dashboard-themes/redhat.yaml "${p}dashboard-themes/"; \
    done

RUN chown -R sandbox:sandbox /sandbox/.hermes

ENV HERMES_HOME=/sandbox/.hermes
ENV TERM=xterm-256color
ENV HERMES_TUI_DIR="/opt/hermes/ui-tui"

RUN HERMES_HOME=/sandbox/.hermes /usr/local/bin/hermes config migrate || true
RUN chown -R sandbox:sandbox /sandbox/.hermes

COPY scripts/hermes-start.sh /usr/local/bin/hermes-start.sh

WORKDIR /workspace

CMD ["/usr/local/bin/hermes-start.sh"]
