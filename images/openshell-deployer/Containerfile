FROM registry.access.redhat.com/ubi10/ubi-minimal
COPY openshell /usr/bin/openshell
RUN microdnf install -y --nodocs bash python3 tar gzip && microdnf clean all && \
    curl -sL "https://mirror.openshift.com/pub/openshift-v4/x86_64/clients/ocp/stable-4.21/openshift-client-linux.tar.gz" | tar xz -C /usr/bin oc kubectl
